# ============================================================
# Polymarket Auto-Trader — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# Keep an encrypted backup (e.g. 1Password, Bitwarden, or
# an encrypted zip) in case the server is wiped.
# ============================================================


# ── Polymarket Wallet ─────────────────────────────────────────
# EOA private key (hex, no 0x prefix) for the SIGNER wallet.
# This wallet signs CLOB orders but does NOT hold funds.
POLYMARKET_PRIVATE_KEY=your_eoa_private_key_hex_no_0x_prefix

# Safe multisig address that holds USDC (the FUNDER wallet).
# All positions and balances appear under this address on-chain.
POLYMARKET_FUNDER_ADDRESS=0xYourSafeMultisigAddress

# Signature type: 0 = EOA, 1 = EIP-1271 (Safe). Default: 2 (magic Safe sig).
POLYMARKET_SIGNATURE_TYPE=2

# CLOB API credentials (optional — generated by py-clob-client automatically
# via create_or_derive_api_creds() if not set. Only needed if you pre-generate.)
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=

# CTF Exchange contract address (updated for Polymarket V2 migration).
# Leave blank to use py-clob-client default. Set when Polymarket announces V2.
# CTF_EXCHANGE_ADDRESS=


# ── AI / Intelligence APIs ────────────────────────────────────
# Anthropic Claude — used for trade scoring (bull/bear debate, consensus vote)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity Sonar — used for real-time news context in opportunity scanner
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# UnusualWhales — smart money / insider signal data
# Get key: https://unusualwhales.com/
UW_API_KEY=your_uw_api_key


# ── Notifications ─────────────────────────────────────────────
# Telegram bot for trade alerts, health monitor pings, whale signals.
# Create a bot: https://t.me/BotFather → /newbot
TELEGRAM_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Telegram user ID (not username). Get it from @userinfobot.
TELEGRAM_CHAT_ID=123456789

# Slack bot token for executor watchdog crash alerts.
# Create at: https://api.slack.com/apps → OAuth & Permissions → Bot Token
# Required scopes: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-...


# ── Executor Service ──────────────────────────────────────────
# Secret used to authenticate requests to the executor HTTP service (port 8888).
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
EXECUTOR_SECRET=your_64_char_hex_secret_here


# ── Discord Monitor ───────────────────────────────────────────
# Discord bot token for the dkxbt call monitor.
# Create at: https://discord.com/developers/applications → Bot → Reset Token
# Note: tokens expire — regenerate if monitor reports HTTP 401.
DISCORD_TOKEN=your_discord_bot_token


# ── Optional / Advanced ──────────────────────────────────────
# Polygon RPC endpoint (used by auto_redeem.py for on-chain redemptions).
# Default uses polygon.drpc.org (public, no key needed).
# Set to a private RPC for better reliability:
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
