# ── Polymarket Auto-Trader Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your own values
# NEVER commit your .env file to git

# Anthropic API Key (for Claude market scoring)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Perplexity API Key (for real-time news context)
# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-YOUR_KEY_HERE

# Polymarket Wallet
# Your Gnosis Safe signer private key (64-char hex, NO 0x prefix)
POLYMARKET_PRIVATE_KEY=YOUR_64_CHAR_HEX_KEY_HERE

# Your Polymarket proxy/funder wallet address (the one shown on polymarket.com)
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE

# Signature type — use 2 for Gnosis Safe (standard Polymarket setup)
POLYMARKET_SIGNATURE_TYPE=2

# Set to true to simulate trades without spending real money
DRY_RUN=false

# Maximum position size per trade in USDC
MAX_POSITION_SIZE=150

# Maximum total portfolio exposure in USDC
MAX_PORTFOLIO_EXPOSURE=1200

# Telegram notifications (optional but recommended)
# Create a bot at: https://t.me/BotFather
# Get your chat_id by messaging: https://t.me/userinfobot
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Unusual Whales API Key (for smart money signals)
# Get yours at: https://unusualwhales.com/api
UW_API_KEY=YOUR_UW_API_KEY_HERE
